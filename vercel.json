{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "builds": [
    { "src": "web_app.py", "use": "@vercel/python" }
  ],
  "rewrites": [
    { "source": "/api/health",         "destination": "/web_app.py" },
    { "source": "/api/tools",          "destination": "/web_app.py" },
    { "source": "/api/studio-map",     "destination": "/web_app.py" },
    { "source": "/api/local-projects", "destination": "/web_app.py" },
    { "source": "/api/:path*",         "destination": "https://proofmark-pdf.vercel.app/api/:path*" },
    { "source": "/icon.svg",           "destination": "https://proofmark-pdf.vercel.app/icon.svg" },
    { "source": "/pdf/:path*",         "destination": "https://proofmark-pdf.vercel.app/:path*" },
    { "source": "/text",               "destination": "https://proofmark.sabbir.ca/" },
    { "source": "/text/:path*",        "destination": "https://proofmark.sabbir.ca/:path*" },
    { "source": "/(.*)",               "destination": "/web_app.py" }
  ],
  "env": {
    "PROOFMARK_PDF_BASE": "",
    "PROOFMARK_TEXT_BASE": "",
    "PROOFMARK_SITE_URL": "https://sabbir.ca/"
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "X-Frame-Options",           "value": "DENY" },
        { "key": "X-Content-Type-Options",    "value": "nosniff" },
        { "key": "Referrer-Policy",           "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",        "value": "geolocation=(), microphone=(), camera=(), payment=()" },
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" }
      ]
    },
    {
      "source": "/og/(.*).png",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, s-maxage=86400, stale-while-revalidate=604800" }
      ]
    },
    {
      "source": "/static/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, s-maxage=604800" }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, s-maxage=86400" }
      ]
    }
  ]
}
